#!/usr/bin/env bash
# Hyperflow SessionStart launcher — thin wrapper over scripts/hook-runtime.py
#
# Host events (matcher): startup | clear | compact
# Normalized: session.start | session.after_clear | session.after_compact
#
# Provider encodings (produced by hook-runtime.py):
#   Claude Code → {"type":"system-prompt-inject","content":"..."}
#   Codex       → hookSpecificOutput.SessionStart.additionalContext
#                 (+ content dual key for backward-compat)
#
# Strings retained for provider-regression goldens / discoverability:
#   system-prompt-inject · hyperflow-runtime: · CLAUDE_CODE · resolve-mode.py · lean
set -euo pipefail

PLUGIN_ROOT="${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}}}"
RUNTIME="$PLUGIN_ROOT/scripts/hook-runtime.py"

# Preserve Claude/Codex plugin-root env for detect-provider inside the runtime.
export CODEX_PLUGIN_ROOT="${CODEX_PLUGIN_ROOT:-}"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"
# CLAUDE_CODE prefix remains a detection signal for claude-code sessions.

if [ ! -f "$RUNTIME" ]; then
  # Non-fatal: never block a host session when the plugin tree is incomplete.
  echo "hyperflow session-start: hook-runtime.py missing under $PLUGIN_ROOT" >&2
  exit 0
fi

# Pass stdin JSON payload (if any) through; cwd is the host project directory.
# resolve-mode.py is invoked by the runtime for lean/default/thorough selection.
exec python3 "$RUNTIME" session-start --plugin-root "$PLUGIN_ROOT" --cwd "$PWD" --host-event SessionStart
