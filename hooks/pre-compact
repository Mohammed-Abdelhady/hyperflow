#!/usr/bin/env bash
# Hyperflow PreCompact launcher — thin wrapper over scripts/hook-runtime.py
#
# Host event: PreCompact (trigger: manual | auto)
# Normalized: session.before_compact
#
# Shared core (hook-runtime.py):
#   - Snapshot volatile chain state to .hyperflow/.precompact.md
#   - Automatic compact allowed only with a fresh .dispatch-auto-compact-ready
#     marker (stale markers are consumed safely; auto without marker is blocked)
#   - Manual compact always passes
#   - Provider block encoding:
#       Claude → {"decision":"block","reason":"..."}
#       Codex  → {"continue":false,"stopReason":"..."} (+ decision/reason dual)
#
# Never blocks the session process itself (exit 0 always).
# Regression golden anchors: .precompact.md · decision · block · dispatch-auto-compact-ready
set -uo pipefail

PLUGIN_ROOT="${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT:-${PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}}}"
RUNTIME="$PLUGIN_ROOT/scripts/hook-runtime.py"

export CODEX_PLUGIN_ROOT="${CODEX_PLUGIN_ROOT:-}"
export CLAUDE_PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-}"

if [ ! -f "$RUNTIME" ]; then
  echo "hyperflow pre-compact: hook-runtime.py missing under $PLUGIN_ROOT" >&2
  exit 0
fi

# Payload on stdin (cwd, transcript_path, trigger). Malformed → non-fatal empty.
exec python3 "$RUNTIME" pre-compact --plugin-root "$PLUGIN_ROOT" --cwd "$PWD" --host-event PreCompact
