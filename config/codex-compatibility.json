  "desktopApp": {
    "builds": [],
    "status": "uncertified",
    "independentOfCli": true,
    "independentOfAppServer": true,
    "attestationSchema": "tests/fixtures/codex/app-attestation.schema.json",
    "attestationRequirements": [
      "issuer",
      "reviewer",
      "commit",
      "tag",
      "createdAt",
      "expiresAt",
      "evidenceDigestSha256",
      "immutableCiRef",
      "platform",
      "appBuild",
      "pluginVersion",
      "redaction",
      "ciProvenance"
    ],
    "notes": [
      "Desktop App support requires a CI-issued attestation bound to exact App build, platform/arch, Hyperflow commit/tag, plugin version, digest, and immutable CI reference.",
      "App-server PASS alone never certifies desktop App."
