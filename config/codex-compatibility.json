{
  "schemaVersion": 1,
  "kind": "codex-compatibility-policy",
  "updated": "2026-07-18",
  "policy": {
    "neverInferAppFromCli": true,
    "neverInferAppFromAppServer": true,
    "pluginListIsNotWorkflowCertification": true,
    "surfacesCertifiedIndependently": [
      "cli",
      "app-server",
      "desktop-app"
    ],
    "windowsAndWslUnsupportedUntilCertified": true,
    "handWrittenAttestationDoesNotUnlockAppClaim": true,
    "notes": [
      "CLI, app-server, and desktop App rows are independent certificates.",
      "A green CLI or app-server lane never sets desktop App support.",
      "A hand-written schema-valid attestation without CI provenance does not unlock App claims.",
      "Initial floor is evidence-derived research context, not a certified claim without certificates."
    ]
  },
  "researchContext": {
    "observedCliVersion": "0.141.0",
    "observedAt": "2026-07-18",
    "source": "local codex-cli --version during full-codex-support research",
    "certificationStatus": "not-certified",
    "comment": "0.141.0 is research context only. Plugin list success and local observation do not certify any CLI, app-server, or App lane. Establish the minimum floor by running the suite backward from a certified currentStable; do not guess."
  },
  "platformPolicy": {
    "supportedWhenCertified": [
      { "os": "linux", "arch": "x86_64" },
      { "os": "linux", "arch": "aarch64" },
      { "os": "macos", "arch": "x86_64" },
      { "os": "macos", "arch": "aarch64" }
    ],
    "unsupportedUntilCertified": [
      { "os": "windows", "arch": "x86_64", "status": "unsupported" },
      { "os": "windows", "arch": "aarch64", "status": "unsupported" },
      { "os": "wsl", "arch": "x86_64", "status": "unsupported" },
      { "os": "wsl", "arch": "aarch64", "status": "unsupported" }
    ]
  },
