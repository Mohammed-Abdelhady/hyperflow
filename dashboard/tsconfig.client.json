{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/client-types",
    "rootDir": "src/client",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client"]
  },
  "include": ["src/client/**/*"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
